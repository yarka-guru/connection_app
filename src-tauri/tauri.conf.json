{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ConnectionApp",
  "version": "3.3.0",
  "identifier": "com.connection-app.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ConnectionApp",
        "width": 650,
        "height": 700,
        "resizable": true,
        "center": true,
        "minWidth": 500,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "macOS": {
      "entitlements": "./Entitlements.plist"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/yarka-guru/connection_app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYxRjNDRkY1MkI1NTM2MzIKUldReU5sVXI5Yy96OGRNdjlHd3BqcTBkL0E4c2ZwUTRlL3VsZXVTdkNWRGxKL1A5ckNYNGdDNVoK"
    }
  }
}
